{
    "version": 2,
    "builds": [
        {
            "src": "server.js",
            "use": "@vercel/node"
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/server.js"
        },
        {
            "source": "/(.*)\\.(css|js|png|jpg|jpeg|gif|ico|svg)",
            "destination": "/public/$1.$2"
        },
        {
            "source": "/login",
            "destination": "/public/login.html"
        },
        {
            "source": "/register",
            "destination": "/public/register.html"
        },
        {
            "source": "/dashboard",
            "destination": "/public/dashboard.html"
        },
        {
            "source": "/(.*)",
            "destination": "/public/index.html"
        }
    ]
}